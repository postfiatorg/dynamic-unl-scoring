# Dynamic UNL Scoring — Devnet Environment
# Non-secret values only. Secrets are injected via GitHub Actions at deploy time.
#
# Secrets set via GitHub Actions: MODAL_ENDPOINT_URL, MODAL_KEY, MODAL_SECRET,
# IPFS_API_URL, IPFS_API_USERNAME, IPFS_API_PASSWORD, IPFS_GATEWAY_URL,
# PINATA_API_KEY, PINATA_API_SECRET, PFTL_WALLET_SECRET,
# PFTL_MEMO_DESTINATION, VL_PUBLISHER_TOKEN, ADMIN_API_KEY

# Database (container-internal hostname)
DATABASE_URL=postgresql://postgres:dev_password@postgres:5432/dynamic_unl_scoring

# PFTL Chain
PFTL_NETWORK=devnet
PFTL_RPC_URL=https://rpc.devnet.postfiat.org

# Validator History Service
VHS_API_URL=https://vhs.devnet.postfiat.org

# RPC Node (for fetching validator manifests)
RPC_URL=https://rpc.devnet.postfiat.org

# Scoring configuration
SCORING_CADENCE_HOURS=672
VL_EFFECTIVE_LOOKAHEAD_HOURS=0.12
SCORING_MODEL_ID=Qwen/Qwen3.6-27B-FP8
SCORING_MODEL_NAME=qwen36-27b-fp8
SCORING_MODEL_REVISION=e89b16ebf1988b3d6befa7de50abc2d76f26eb09
SCORING_DISABLE_THINKING=true
SCORING_GPU_TYPE=H100
SCORING_QUANTIZATION=
SCORING_ATTENTION_BACKEND=
SCORING_SGLANG_IMAGE_TAG=lmsysorg/sglang:nightly-dev-cu13-20260430-e60c60ef@sha256:5d9ec71597ade6b8237d61ae6f01b976cb3d5ad2c1e3cf4e0acaf27a9ff49a65
SCORING_REASONING_PARSER=qwen3
SCORING_TP=1
SCORING_MEM_FRACTION=0.75
SCORING_CHUNKED_PREFILL=4096
SCORING_MAX_REQS=1
SGLANG_FLASHINFER_WORKSPACE_SIZE=2147483648
EXCLUDED_VALIDATOR_SERVER_VERSIONS=3.0.0

# Round announcement (commit-reveal windows, in seconds)
# Devnet uses short windows so a full commit-reveal round can be tested in minutes
ANNOUNCEMENT_COMMIT_WINDOW_SECONDS=900
ANNOUNCEMENT_REVEAL_WINDOW_SECONDS=300
ANNOUNCEMENT_REVEAL_GAP_SECONDS=0

# UNL selection (devnet: 6 validators competing for 3 slots)
UNL_MAX_SIZE=3
UNL_SCORE_CUTOFF=40
UNL_MIN_SCORE_GAP=5

# Application
DEBUG=false
LOG_LEVEL=INFO
