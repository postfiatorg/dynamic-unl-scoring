# Dynamic UNL Scoring — Devnet Environment
# Non-secret values only. Secrets are injected via GitHub Actions at deploy time.
#
# Secrets set via GitHub Actions: MODAL_ENDPOINT_URL, IPFS_API_URL,
# IPFS_API_USERNAME, IPFS_API_PASSWORD, IPFS_GATEWAY_URL, PINATA_API_KEY,
# PINATA_API_SECRET, PFTL_WALLET_SECRET, PFTL_MEMO_DESTINATION,
# VL_PUBLISHER_TOKEN, ADMIN_API_KEY

# Database (container-internal hostname)
DATABASE_URL=postgresql://postgres:dev_password@postgres:5432/dynamic_unl_scoring

# PFTL Chain
PFTL_NETWORK=devnet
PFTL_RPC_URL=https://rpc.devnet.postfiat.org

# Validator History Service
VHS_API_URL=https://vhs.devnet.postfiat.org

# RPC Node (for fetching validator manifests)
RPC_URL=https://rpc.devnet.postfiat.org

# Scoring configuration
SCORING_CADENCE_HOURS=168
SCORING_MODEL_ID=Qwen/Qwen3-Next-80B-A3B-Instruct-FP8
SCORING_MODEL_NAME=qwen3-next-80b-instruct

# UNL selection (devnet: 6 validators competing for 3 slots)
UNL_MAX_SIZE=3
UNL_SCORE_CUTOFF=40
UNL_MIN_SCORE_GAP=5

# Application
DEBUG=false
LOG_LEVEL=INFO
