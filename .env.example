# Dynamic UNL Scoring — Local Development Environment
#
# Copy this file to .env:  cp .env.example .env
# Fill in only what you need. All settings have safe defaults in config.py,
# so the service starts with an empty .env (as long as PostgreSQL is running).
#
# Note: DATABASE_URL here uses localhost (for running outside Docker).
# docker-compose.yml overrides this to use the postgres container hostname.

# Database
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/dynamic_unl_scoring

# PFTL Chain (on-chain memo publishing)
# Leave empty to disable on-chain publishing during development.
PFTL_RPC_URL=
PFTL_WALLET_SECRET=
PFTL_MEMO_DESTINATION=
PFTL_NETWORK=devnet

# Validator History Service
VHS_API_URL=https://vhs.testnet.postfiat.org

# Modal LLM endpoint (OpenAI-compatible)
# Required to trigger scoring runs. Get the URL from: modal deploy infra/deploy_endpoint.py
MODAL_ENDPOINT_URL=

# IPFS audit trail
# API URL = node endpoint for uploading/pinning (requires auth)
# Gateway URL = public endpoint for reading by CID (no auth)
IPFS_API_URL=
IPFS_API_USERNAME=
IPFS_API_PASSWORD=
IPFS_GATEWAY_URL=

# Pinata (secondary IPFS pinning provider for audit trail redundancy)
# Leave empty to disable secondary pinning.
# PINATA_GATEWAY_URL defaults to the public shared gateway; override only
# if you have a dedicated gateway subdomain.
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=

# UNL selection
UNL_SCORE_CUTOFF=40
UNL_MAX_SIZE=35
UNL_MIN_SCORE_GAP=5

# Scoring configuration
SCORING_CADENCE_HOURS=168
SCORING_MODEL_ID=Qwen/Qwen3-Next-80B-A3B-Instruct-FP8
SCORING_MODEL_NAME=qwen3-next-80b-instruct
SCORING_TEMPERATURE=0
SCORING_MAX_TOKENS=16384
SCORING_MEMO_TYPE=pf_dynamic_unl

# Scheduler
SCHEDULER_CHECK_INTERVAL_SECONDS=3600
SCHEDULER_STARTUP_DELAY_SECONDS=300

# VL Publisher (signed Validator List)
VL_PUBLISHER_TOKEN=
VL_EXPIRATION_DAYS=500
# Hours between signing time and the VL's activation timestamp. Every validator
# caches the pending blob and activates it on the same consensus tick once
# effective_time is reached — collapses the 5-minute polling propagation window
# to sub-second consensus precision. 0 = activate immediately on fetch.
VL_EFFECTIVE_LOOKAHEAD_HOURS=1

# RPC Node (for fetching validator manifests at VL generation time)
RPC_URL=https://rpc.testnet.postfiat.org

# VL Distribution (GitHub Pages)
# The scoring service commits each round's signed VL to a file in
# postfiatorg/postfiatorg.github.io so validators reach it at
# postfiat.org/{env}_vl.json via GitHub Pages.
# Token must be a fine-grained PAT scoped to contents:write on the
# target repo only. Per-environment file path differentiates the two
# deployments (devnet writes to devnet_vl.json, testnet to
# testnet_vl.json) using the same service account and token.
GITHUB_PAGES_TOKEN=
GITHUB_PAGES_REPO=postfiatorg/postfiatorg.github.io
GITHUB_PAGES_FILE_PATH=
GITHUB_PAGES_BRANCH=main
GITHUB_PAGES_COMMIT_AUTHOR_NAME=PostFiat Scoring Service
GITHUB_PAGES_COMMIT_AUTHOR_EMAIL=layer-one-agent@deltahash.net

# Admin
ADMIN_API_KEY=

# API pagination
DEFAULT_PAGE_LIMIT=20

# Application
DEBUG=true
LOG_LEVEL=DEBUG

# OpenRouter (for standalone benchmark scripts only, not used by the service)
OPENROUTER_API_KEY=
