# Dynamic UNL Scoring — Testnet Environment
# Non-secret values only. Secrets are injected via GitHub Actions at deploy time.

# Database (container-internal hostname)
DATABASE_URL=postgresql://postgres:dev_password@postgres:5432/dynamic_unl_scoring

# PFTL Chain
PFTL_NETWORK=testnet
PFTL_RPC_URL=https://rpc.testnet.postfiat.org

# Validator History Service
VHS_API_URL=https://vhs.testnet.postfiat.org

# Scoring configuration
SCORING_CADENCE_HOURS=168
SCORING_MODEL_ID=Qwen/Qwen3.6-27B-FP8
SCORING_MODEL_NAME=qwen36-27b-fp8
SCORING_DISABLE_THINKING=true

# Application
DEBUG=false
LOG_LEVEL=INFO
